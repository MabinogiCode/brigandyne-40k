{
  "name": "brigandyne-40k",
  "version": "0.6.2",
  "description": "Système Foundry VTT — Warhammer 40,000 : Brigandyne",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild src/brigandyne40k.ts --bundle --format=esm --outfile=dist/brigandyne40k.mjs --sourcemap --target=es2023",
    "typecheck": "tsc --noEmit",
    "pack": "node tools/compile-packs.ts",
    "import": "node tools/import-content.ts",
    "test": "node --test \"test/*.test.ts\""
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.0.3",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
