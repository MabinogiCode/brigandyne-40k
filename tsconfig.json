{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "declaration": true,
    "declarationDir": "dist/types",
    "sourceMap": false,
    "lib": ["ES2022", "DOM"],
    "types": ["@league-of-foundry-developers/foundry-vtt-types"]
  },
  "include": ["module/**/*.ts", "test/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tools", "packs"]
}
