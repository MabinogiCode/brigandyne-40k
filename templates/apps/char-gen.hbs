{{!-- Assistant (wizard) de création de personnage --}}
<div class="wizard-body">
  {{#if noPacks}}
    <p class="warn">Les compendiums (Espèces, Carrières) ne sont pas disponibles.</p>
  {{else if blocked}}
    <div class="wizard-blocked">
      <i class="fa-solid fa-user-lock"></i>
      <h2>{{localize "BRIG.CharGen.lock.blockedTitle"}}</h2>
      <p>{{localize "BRIG.CharGen.lock.blockedBody"}}</p>
      <button type="button" class="btn-request-new" data-action="wizRequestNew">
        <i class="fa-solid fa-user-plus"></i> {{localize "BRIG.CharGen.lock.askNew"}}
      </button>
    </div>
  {{else}}
  <div class="wizard-layout">
    <aside class="wizard-stages">
      {{#each stages}}
        <button type="button" class="stage {{#if active}}active{{/if}} {{#if done}}done{{/if}}" data-action="wizGoto" data-i="{{i}}">
          <span class="num">{{add i 1}}</span> {{label}}
        </button>
      {{/each}}
    </aside>

    <section class="wizard-content">
      {{#if (eq stepId 'identity')}}
        <label class="block">Nom <input type="text" name="name" value="{{draft.name}}" /></label>
        <div class="form-grid two">
          <label>Espèce
            <select name="speciesId" data-refresh><option value="">—</option>
              {{#each species}}<option value="{{id}}" {{#if (eq id ../draft.speciesId)}}selected{{/if}}>{{name}}</option>{{/each}}
            </select>
          </label>
          <label>Carrière
            <select name="careerId" data-refresh><option value="">—</option>
              {{#each careerGroups}}<optgroup label="{{label}}">
                {{#each careers}}<option value="{{id}}" {{#if (eq id ../../draft.careerId)}}selected{{/if}}>{{name}}</option>{{/each}}
              </optgroup>{{/each}}
            </select>
          </label>
        </div>
        <label class="block">Rôle
          <select name="role">{{#each roles as |lab key|}}<option value="{{key}}" {{#if (eq key ../draft.role)}}selected{{/if}}>{{localize lab}}</option>{{/each}}</select>
        </label>
        {{#if speciesName}}
          <div class="preview species-preview">
            <h4><i class="fa-solid fa-dna"></i> {{speciesName}} <span class="lifestyle">— Destin {{destin}}</span></h4>
            {{#if speciesDesc}}<p class="lore">{{speciesDesc}}</p>{{/if}}
            {{#if (brigOr speciesLifespan speciesSize)}}<p class="lore-meta">{{#if speciesLifespan}}<i class="fa-solid fa-hourglass-half"></i> {{speciesLifespan}}{{/if}}{{#if speciesSize}} &nbsp;·&nbsp; <i class="fa-solid fa-ruler-vertical"></i> {{speciesSize}}{{/if}}</p>{{/if}}
            <div class="char-mini-grid">{{#each chars}}<div class="mini" data-tooltip="{{tip}}"><span class="k">{{localize abbr}}</span><span class="v">{{base}}</span></div>{{/each}}</div>
            {{#if speciesTraits.length}}<div class="chip-row">{{#each speciesTraits}}<span class="chip trait">{{this}}</span>{{/each}}</div>{{/if}}
            {{#if speciesLimits.length}}<p class="lore-meta"><i class="fa-solid fa-arrow-up-from-bracket"></i> Plafonds : {{#each speciesLimits}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>{{/if}}
          </div>
        {{/if}}
        {{#if careerName}}
          <div class="preview career-preview">
            <h4><i class="fa-solid fa-briefcase"></i> {{careerName}} <span class="lifestyle">· niveau de vie : {{lifestyle}}</span></h4>
            {{#if careerQuote}}<p class="quote">« {{careerQuote}} »</p>{{/if}}
            {{#if careerDesc}}<div class="lore">{{{careerDesc}}}</div>{{/if}}
            {{#if specialtiesInfo.length}}<p class="chip-label">Spécialités disponibles</p><div class="chip-row">{{#each specialtiesInfo}}<span class="chip" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>{{/if}}
            {{#if talentsInfo.length}}<p class="chip-label">Talents disponibles</p><div class="chip-row">{{#each talentsInfo}}<span class="chip talent" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>{{/if}}
            {{#if careerBaseEquipment}}<p class="chip-label"><i class="fa-solid fa-box"></i> Équipement de base du groupe</p><div class="lore starting-equip">{{{careerBaseEquipment}}}</div>{{/if}}
          </div>
        {{/if}}

      {{else if (eq stepId 'characteristics')}}
        {{#if methodChosen}}
          {{#if showMethodTabs}}
            <div class="gen-method-active">
              <span><i class="fa-solid fa-circle-check"></i> {{localize "BRIG.CharGen.method.label"}} : <strong>{{methodLabel}}</strong></span>
              <button type="button" class="link-request" data-action="genMethodReset"><i class="fa-solid fa-rotate-left"></i> Changer de méthode</button>
            </div>
          {{else}}
            <div class="gen-method-locked">
              <span><i class="fa-solid fa-lock"></i> {{localize "BRIG.CharGen.method.label"}} : <strong>{{methodLabel}}</strong></span>
              <button type="button" class="link-request" data-action="wizRequestMethod"><i class="fa-solid fa-hand"></i> {{localize "BRIG.CharGen.lock.askMethod"}}</button>
            </div>
          {{/if}}
        {{else}}
          <div class="gen-choose">
            <h3>{{localize "BRIG.CharGen.method.choose"}}</h3>
            <div class="gen-choose-cards">
              <button type="button" class="choose-card" data-action="genMethod" data-method="points">
                <i class="fa-solid fa-sliders"></i>
                <span class="cc-title">{{localize "BRIG.CharGen.method.points"}}</span>
                <span class="cc-desc">{{localize "BRIG.CharGen.method.pointsDesc"}}</span>
              </button>
              <button type="button" class="choose-card" data-action="genMethod" data-method="roll">
                <i class="fa-solid fa-dice"></i>
                <span class="cc-title">{{localize "BRIG.CharGen.method.roll"}}</span>
                <span class="cc-desc">{{localize "BRIG.CharGen.method.rollDesc"}}</span>
              </button>
            </div>
            {{#if locksApply}}<p class="warn-final"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "BRIG.CharGen.method.finalWarn"}}</p>{{/if}}
          </div>
        {{/if}}

        {{#if methodChosen}}
        <div class="gen-context">
          <span><i class="fa-solid fa-dna"></i> {{#if speciesName}}{{speciesName}}{{else}}<em>espèce ?</em>{{/if}}</span>
          <span><i class="fa-solid fa-briefcase"></i> {{#if careerName}}{{careerName}}{{else}}<em>carrière ?</em>{{/if}}</span>
          <span><i class="fa-solid fa-user-tag"></i> {{localize (concat "BRIG.Role." draft.role)}}</span>
        </div>
        {{#if (eq gen.method 'roll')}}
          <div class="gen-roll-bar">
            {{#if rollLocked}}
              <span class="roll-locked"><i class="fa-solid fa-lock"></i> {{localize "BRIG.CharGen.lock.diceThrown"}}</span>
              <button type="button" class="link-request" data-action="wizRequestReroll"><i class="fa-solid fa-hand"></i> {{localize "BRIG.CharGen.lock.askReroll"}}</button>
            {{else}}
              <button type="button" class="roll-btn" data-action="genRoll"><i class="fa-solid fa-dice-d6"></i> {{localize "BRIG.CharGen.method.rollAction"}}</button>
            {{/if}}
            {{#if gen.rolledDisplay.length}}
              <span class="rolled">{{#each gen.rolledDisplay}}<span class="rv{{#if dropped}} dropped{{/if}}{{#if used}} used{{/if}}">{{v}}</span>{{/each}}</span>
              {{#if gen.dropped}}<span class="dropped-note">{{localize "BRIG.CharGen.method.dropped"}} {{gen.dropped}}</span>{{/if}}
            {{else}}<span class="hint">{{localize "BRIG.CharGen.method.rollHint"}}</span>{{/if}}
          </div>
        {{else}}
          <p class="points-counter">{{localize "BRIG.CharGen.method.pointsRemaining"}} <strong data-points-remaining>{{gen.pointsRemaining}}</strong> / {{gen.pointsTotal}} <span class="hint">{{localize "BRIG.CharGen.method.pointsRange"}}</span></p>
        {{/if}}

        <div class="gen-table-wrap">
          <table class="gen-table">
            <thead>
              <tr><th class="rh"></th>{{#each gen.rows}}<th data-tooltip="{{tip}}">{{localize abbr}}</th>{{/each}}</tr>
            </thead>
            <tbody>
              <tr class="r-base"><th class="rh">Base</th>{{#each gen.rows}}<td data-tooltip="Base d'espèce">{{base}}</td>{{/each}}</tr>
              <tr class="r-ctrl">
                <th class="rh">{{#if (eq gen.method 'roll')}}Tirage{{else}}Points{{/if}}</th>
                {{#each gen.rows}}<td>
                  {{#if (eq ../gen.method 'roll')}}
                    <select name="assign.{{key}}">
                      <option value="">—</option>
                      {{#each options}}<option value="{{i}}" {{#if (eq i ../assignedIdx)}}selected{{/if}}>{{v}}{{#if used}} •{{/if}}</option>{{/each}}
                    </select>
                  {{else}}
                    <input type="number" name="points.{{key}}" value="{{point}}" min="0" max="20" />
                  {{/if}}
                </td>{{/each}}
              </tr>
              <tr class="r-total"><th class="rh">Total</th>{{#each gen.rows}}<td data-total="{{key}}">{{total}}</td>{{/each}}</tr>
            </tbody>
          </table>
        </div>

        {{#unless noPsy}}
        <details class="psy-draw">
          <summary><i class="fa-solid fa-brain"></i> Psyker — prélever vers PSY (max 10/comp · COM compte double)</summary>
          <div class="psy-grid">
            {{#each gen.rows}}<label class="pd">{{localize abbr}}<input type="number" name="psyDraw.{{key}}" value="{{psyDraw}}" min="0" max="10" /></label>{{/each}}
          </div>
          <div class="psy-result">PSY = <strong data-total="psy">{{gen.psyTotal}}</strong> <span class="hint">(max {{gen.psyCap}} à la création)</span></div>
        </details>
        {{/unless}}

        <div class="derived-preview">
          <span>PV <strong>{{pv}}</strong></span><span>SF <strong>{{sf}}</strong></span>
          {{#if (eq gen.method 'roll')}}<span data-tooltip="Somme des 12 résultats conservés (hors dé écarté)">Somme des dés <strong>{{gen.diceSum}}</strong></span>{{/if}}
          <span data-tooltip="Total des 13 compétences (base d'espèce + répartition) — pour jauger la puissance globale">Total compétences <strong>{{gen.charTotal}}</strong></span>
          {{#unless gen.valid}}<span class="gen-warn"><i class="fa-solid fa-triangle-exclamation"></i> {{#if (eq gen.method 'roll')}}Assigne chaque résultat (un par compétence){{else}}≤ {{gen.pointsTotal}} pts, max 20/comp{{/if}}</span>{{/unless}}
        </div>
        {{/if}}

      {{else if (eq stepId 'traits')}}
        {{!-- Archétype --}}
        <div class="traits-section">
          <h3><i class="fa-solid fa-paw"></i> Archétype</h3>
          <p class="hint">L'archétype façonne la personnalité et l'allure du personnage (symbolisé par un animal). Il applique des modificateurs aux caractéristiques.</p>
          {{#if archetypes.length}}
            <label class="block">Archétype
              <select name="archetypeId" data-refresh>
                <option value="">— Aucun —</option>
                {{!-- Un seul ../ : #if est transparent pour la résolution des chemins,
                     seul #each crée un cadre — ../../ débordait et le select revenait
                     sur « Aucun » à chaque re-render (perte de l'archétype au clic suivant). --}}
                {{#each archetypes}}<option value="{{id}}" {{#if (eq id ../draft.archetypeId)}}selected{{/if}}>{{name}}</option>{{/each}}
              </select>
            </label>
            {{#if archetypeDoc}}
              <div class="preview archetype-preview">
                <h4><i class="fa-solid fa-paw"></i> {{archetypeName}}</h4>
                {{#if archetypeDoc.system.description}}<div class="lore">{{{archetypeDoc.system.description}}}</div>{{/if}}
              </div>
            {{/if}}
          {{else}}
            <p class="warn-soft"><i class="fa-solid fa-circle-info"></i> Le compendium des Archétypes n'est pas encore disponible. Vous pourrez choisir votre archétype ultérieurement.</p>
          {{/if}}
        </div>

        {{!-- Vices & Vertus (pilotés par l'archétype) --}}
        <div class="traits-section">
          <h3><i class="fa-solid fa-yin-yang"></i> Vices & Vertus</h3>
          {{#if archetypeDoc}}
            <p class="hint">Les vices & vertus découlent de l'archétype : un (ou plusieurs) accordé(s) d'office, plus un choix dans la liste.</p>
            {{#if archFixed.length}}
              <p class="chip-label">Accordé(s) d'office (+1)</p>
              <div class="chip-row">{{#each archFixed}}<span class="chip {{kind}}" data-tooltip="{{tip}}">{{label}} +1</span>{{/each}}</div>
            {{/if}}
            {{#if archSlots.length}}
              <p class="chip-label">À choisir ({{archCount}} · +1 chacun)</p>
              <div class="form-grid two">
                {{#each archSlots}}
                  <label>Choix {{add i 1}}
                    <select name="archTrait.{{i}}" data-refresh>
                      <option value="">—</option>
                      {{#each ../archChoices}}<option value="{{key}}" {{#if (eq key ../selected)}}selected{{/if}}>{{label}}</option>{{/each}}
                    </select>
                  </label>
                {{/each}}
              </div>
            {{/if}}
            {{#if archTalents.length}}
              <p class="chip-label"><i class="fa-solid fa-star"></i> Talents accessibles (achetables avec l'XP)</p>
              <div class="chip-row">{{#each archTalents}}<span class="chip talent" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>
            {{/if}}
          {{else}}
            <p class="warn-soft"><i class="fa-solid fa-circle-info"></i> Choisis un archétype ci-dessus pour déterminer tes vices & vertus.</p>
          {{/if}}
        </div>

        {{!-- Atouts (info — le tirage se fait à l'étape suivante) --}}
        {{#if careerName}}
        <div class="traits-section">
          <h3><i class="fa-solid fa-star"></i> Atouts de carrière</h3>
          <p>Votre personnage commence avec <strong>*CNS*−1</strong> atouts (spécialités et/ou Talents), à tirer à l'étape suivante.</p>
          <p>CNS = <strong>{{cnsValue}}</strong> → *CNS* = {{cnsBonus}} → <strong>{{numAtouts}} atout{{#if (gt numAtouts 1)}}s{{/if}}</strong> à tirer parmi les {{poolSize}} de la carrière.</p>
        </div>
        {{/if}}

      {{else if (eq stepId 'atouts')}}
        <div class="traits-section">
          <h3><i class="fa-solid fa-star"></i> Atouts de départ</h3>
          {{#if careerName}}
            <p>Votre personnage commence avec <strong>*CNS*−1</strong> atouts : CNS <strong>{{cnsValue}}</strong> → *CNS* = {{cnsBonus}} → <strong>{{numAtouts}} atout{{#if (gt numAtouts 1)}}s{{/if}}</strong>.</p>
            <p class="hint">Répartissez-les comme vous le souhaitez entre spécialités et Talents. Chaque tirage (2D10) propose <strong>deux options</strong> : retenez celle qui correspond le plus à votre personnage.</p>
            {{#if occulteExcluded}}<p class="warn-soft"><i class="fa-solid fa-circle-info"></i> PSY à 0 : les spécialités occultes sont exclues du tirage.</p>{{/if}}

            {{#if atoutsChosen.length}}
              <p class="chip-label"><i class="fa-solid fa-circle-check"></i> Atouts acquis ({{atoutsChosen.length}}/{{numAtouts}})</p>
              <div class="chip-row">{{#each atoutsChosen}}<span class="chip {{#if (eq kind 'talent')}}talent{{/if}}" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>
            {{/if}}

            {{#if pendingDraw}}
              <p class="chip-label"><i class="fa-solid fa-dice"></i> Tirage en cours — {{pendingDraw.kindLabel}} : choisissez une option</p>
              <div class="gen-choose-cards">
                {{#each pendingDraw.options}}
                  <button type="button" class="choose-card" data-action="atoutPick" data-name="{{name}}">
                    <i class="fa-solid fa-star"></i>
                    <span class="cc-title">{{name}}</span>
                    {{#if tip}}<span class="cc-desc">{{tip}}</span>{{/if}}
                  </button>
                {{/each}}
              </div>
            {{else if atoutsRemaining}}
              <p class="chip-label">Encore <strong>{{atoutsRemaining}}</strong> atout{{#if (gt atoutsRemaining 1)}}s{{/if}} à tirer — choisissez une catégorie :</p>
              <div class="gen-choose-cards">
                <button type="button" class="choose-card" data-action="atoutDraw" data-kind="specialty" {{#unless specPoolCount}}disabled{{/unless}}>
                  <i class="fa-solid fa-bullseye"></i>
                  <span class="cc-title">Tirer une spécialité</span>
                  <span class="cc-desc">{{specPoolCount}} disponible{{#if (gt specPoolCount 1)}}s{{/if}}</span>
                </button>
                <button type="button" class="choose-card" data-action="atoutDraw" data-kind="talent" {{#unless talPoolCount}}disabled{{/unless}}>
                  <i class="fa-solid fa-wand-sparkles"></i>
                  <span class="cc-title">Tirer un Talent</span>
                  <span class="cc-desc">{{talPoolCount}} disponible{{#if (gt talPoolCount 1)}}s{{/if}}</span>
                </button>
              </div>
            {{else}}
              <p class="hint"><i class="fa-solid fa-circle-check"></i> Tous les atouts de départ sont tirés.</p>
            {{/if}}

            {{#unless locksApply}}{{#if atoutsChosen.length}}
              <button type="button" class="link-request" data-action="atoutsReset"><i class="fa-solid fa-rotate-left"></i> Recommencer les tirages</button>
            {{/if}}{{/unless}}

            {{#if specialtiesInfo.length}}<p class="chip-label">Spécialités de la carrière</p><div class="chip-row">{{#each specialtiesInfo}}<span class="chip faded" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>{{/if}}
            {{#if talentsInfo.length}}<p class="chip-label">Talents de la carrière</p><div class="chip-row">{{#each talentsInfo}}<span class="chip talent faded" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>{{/if}}
          {{else}}
            <p class="warn-soft"><i class="fa-solid fa-circle-info"></i> Choisissez d'abord une carrière (étape Identité) pour tirer vos atouts.</p>
          {{/if}}
        </div>

      {{else if (eq stepId 'details')}}
        <div class="details-grid">
          <label>Âge <input type="text" name="details.age" value="{{details.age}}" /></label>
          <label>Taille <input type="text" name="details.height" value="{{details.height}}" /></label>
          <label>Poids <input type="text" name="details.weight" value="{{details.weight}}" /></label>
          <label>Yeux <input type="text" name="details.eyes" value="{{details.eyes}}" /></label>
          <label>Cheveux <input type="text" name="details.hair" value="{{details.hair}}" /></label>
          <label>Sexe <input type="text" name="details.gender" value="{{details.gender}}" /></label>
          <label>Monde natal <input type="text" name="details.homeworld" value="{{details.homeworld}}" /></label>
          <label class="wide">Motivation <input type="text" name="details.motivation" value="{{details.motivation}}" /></label>
        </div>

      {{else if (eq stepId 'summary')}}
        <h3 class="recap-name">{{draft.name}}</h3>
        <ul class="recap">
          <li><i class="fa-solid fa-dna"></i> Espèce : <strong>{{#if speciesName}}{{speciesName}}{{else}}—{{/if}}</strong></li>
          <li><i class="fa-solid fa-briefcase"></i> Carrière : <strong>{{#if careerName}}{{careerName}}{{else}}—{{/if}}</strong> {{#if lifestyle}}({{lifestyle}}){{/if}}</li>
          <li><i class="fa-solid fa-user-tag"></i> Rôle : {{localize (concat "BRIG.Role." draft.role)}}</li>
          <li><i class="fa-solid fa-heart"></i> PV <strong>{{pv}}</strong> · SF <strong>{{sf}}</strong>{{#if destin}} · Destin <strong>{{destin}}</strong>{{/if}}</li>
          {{#if archetypeName}}<li><i class="fa-solid fa-paw"></i> Archétype : <strong>{{archetypeName}}</strong></li>{{/if}}
          {{#if archGranted.length}}<li><i class="fa-solid fa-yin-yang"></i> Vices & vertus : {{#each archGranted}}<strong data-tooltip="{{tip}}">{{label}}</strong> +1{{#unless @last}}, {{/unless}}{{/each}}</li>{{/if}}
        </ul>
        <div class="recap-chars">{{#each chars}}<span class="rc" data-tooltip="{{tip}}">{{localize abbr}} <b>{{value}}</b></span>{{/each}}</div>
        {{#if careerName}}
          <p class="chip-label"><i class="fa-solid fa-star"></i> Atouts de départ : <strong>{{atoutsChosen.length}}</strong>/{{numAtouts}} (CNS {{cnsValue}} → *CNS*={{cnsBonus}} → {{cnsBonus}}−1={{numAtouts}})</p>
          {{#if atoutsChosen.length}}
            <div class="chip-row">{{#each atoutsChosen}}<span class="chip {{#if (eq kind 'talent')}}talent{{/if}}" data-tooltip="{{tip}}">{{name}}</span>{{/each}}</div>
          {{/if}}
          {{#if atoutsRemaining}}<p class="warn-soft"><i class="fa-solid fa-triangle-exclamation"></i> Il reste {{atoutsRemaining}} atout{{#if (gt atoutsRemaining 1)}}s{{/if}} à tirer (étape Atouts).</p>{{/if}}
        {{/if}}
        {{#if careerBaseEquipment}}
          <p class="chip-label"><i class="fa-solid fa-box"></i> Équipement de base du groupe</p>
          <div class="lore starting-equip">{{{careerBaseEquipment}}}</div>
        {{/if}}
        {{#if careerStartingEquipment}}
          <p class="chip-label"><i class="fa-solid fa-box-open"></i> Équipement additionnel de la carrière</p>
          <div class="lore starting-equip">{{{careerStartingEquipment}}}</div>
        {{/if}}
        {{#unless editMode}}<p class="attach-note"><i class="fa-solid fa-link"></i> Le personnage sera créé et rattaché à <strong>toi</strong> ({{draft.name}} deviendra ton personnage).</p>{{/unless}}
      {{/if}}
    </section>
  </div>

  <footer class="wizard-footer">
    <button type="button" class="btn-cancel" data-action="wizCancel"><i class="fa-solid fa-xmark"></i> Annuler</button>
    <div class="spacer"></div>
    {{#unless first}}<button type="button" data-action="wizPrev"><i class="fa-solid fa-caret-left"></i> Précédent</button>{{/unless}}
    {{#if last}}
      <button type="button" class="btn-finish" data-action="wizFinish"><i class="fa-solid fa-check"></i> {{#if editMode}}Appliquer{{else}}Créer le personnage{{/if}}</button>
    {{else}}
      <button type="button" class="btn-next" data-action="wizNext">Suivant <i class="fa-solid fa-caret-right"></i></button>
    {{/if}}
  </footer>
  {{/if}}
</div>
