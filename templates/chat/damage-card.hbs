{{!-- Carte de dégâts --}}
<div class="brigandyne-40k chat-card damage-card">
  <header class="card-header">
    <div class="card-titles">
      <h3 class="card-title"><i class="fa-solid fa-burst"></i> Dégâts — {{label}}</h3>
    </div>
  </header>
  <div class="card-result">
    <span class="roll-total">{{total}}</span>
    <span class="roll-vs">{{type}}{{#if ap}} · PA {{ap}}{{/if}}{{#if ignoreArmor}} · ignore armures{{/if}}</span>
  </div>
  {{#if hasTargets}}
    <div class="card-meta">
      {{#each rows}}
        <div class="meta-line">
          <span class="meta-label">{{name}}</span>
          <span class="meta-value">−{{applied}} PV <span class="mod-chip">prot {{prot}}</span></span>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="card-meta"><em>Aucune cible sélectionnée — dégâts bruts {{total}}.</em></div>
  {{/if}}
</div>
